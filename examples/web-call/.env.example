# ============================================================
# Sharyx Web Call — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API keys.
#   cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# Server
# ----------------------------------------------------------
PORT=3000

# ----------------------------------------------------------
# LLM Provider  (which model powers the AI responses)
# ----------------------------------------------------------
# Supported values: openai | gemini
LLM_PROVIDER=openai

# OpenAI  — required when LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4o-mini          # optional, defaults to gpt-4o-mini

# Google Gemini — required when LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-1.5-flash     # optional, defaults to gemini-1.5-flash

# ----------------------------------------------------------
# STT Provider  (Speech-to-Text / transcription)
# ----------------------------------------------------------
# Currently only Deepgram is supported.
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=your-deepgram-key-here
DEEPGRAM_MODEL=nova-2             # optional, defaults to nova-2

# ----------------------------------------------------------
# TTS Provider  (Text-to-Speech / voice synthesis)
# ----------------------------------------------------------
# Supported values: cartesia | elevenlabs
TTS_PROVIDER=cartesia

# Cartesia — required when TTS_PROVIDER=cartesia
CARTESIA_API_KEY=your-cartesia-key-here
CARTESIA_VOICE_ID=694f9389-aac1-45b6-b726-9d9369183238
CARTESIA_MODEL=sonic-english      # optional, defaults to sonic-english

# ElevenLabs — required when TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=your-elevenlabs-key-here
ELEVENLABS_VOICE_ID=JBFucSot9Snd9hQU9nzV
ELEVENLABS_MODEL=eleven_turbo_v2_5 # optional, defaults to eleven_turbo_v2_5

# ----------------------------------------------------------
# Redis  (session / memory persistence)
# ----------------------------------------------------------
REDIS_URL=redis://localhost:6379
