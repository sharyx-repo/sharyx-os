{
  "name": "sharyx-os",
  "version": "1.1.0",
  "description": "Provider-agnostic real-time AI voice agent orchestration framework",
  "author": "Sharyx AI Team <team@sharyx.ai>",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sharyx-voice-ai/sharyx-os.git"
  },
  "keywords": [
    "voice-ai",
    "ai-agent",
    "stt",
    "tts",
    "llm",
    "real-time",
    "telephony",
    "twilio",
    "webrtc"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "ws": "^8.14.2",
    "zod": "^3.22.4"
  },
  "peerDependencies": {
    "@deepgram/sdk": ">=3.0.0",
    "cartesia-js": ">=2.0.0",
    "elevenlabs": ">=0.1.0",
    "ioredis": ">=5.0.0",
    "openai": ">=4.0.0",
    "plivo": ">=4.0.0",
    "twilio": ">=4.0.0",
    "googleapis": ">=100.0.0",
    "@hubspot/api-client": ">=11.0.0"
  },
  "peerDependenciesMeta": {
    "@deepgram/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "twilio": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "elevenlabs": {
      "optional": true
    },
    "cartesia-js": {
      "optional": true
    },
    "plivo": {
      "optional": true
    },
    "googleapis": {
      "optional": true
    },
    "@hubspot/api-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hubspot/api-client": "^11.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.8.2",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "eslint": "^8.50.0",
    "express": "^4.18.2",
    "googleapis": "^126.0.0",
    "ioredis": "^5.10.1",
    "openai": "^4.104.0",
    "tsup": "^8.0.1",
    "typescript": "^5.2.2",
    "vitest": "^1.4.0"
  }
}
